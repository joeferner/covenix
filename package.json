{
  "name": "zodec",
  "version": "0.1.0",
  "description": "Zod-powered decorators for Express APIs — typed routes, runtime validation, and accurate OpenAPI from a single source of truth.",
  "license": "MIT",
  "author": "Joe Ferner <joe@fernsroth.com>",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "pre-commit": "npm run format && npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "express": "^5.2.1",
    "openapi-types": "^12.1.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "http-errors": "^2.0.1",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
