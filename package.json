{
  "name": "covenix",
  "version": "0.1.0",
  "description": "Zod-powered decorators for Express APIs — typed routes, runtime validation, and accurate OpenAPI from a single source of truth.",
  "license": "MIT",
  "author": "Joe Ferner <joe@fernsroth.com>",
  "homepage": "https://github.com/joeferner/covenix#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joeferner/covenix.git"
  },
  "bugs": {
    "url": "https://github.com/joeferner/covenix/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "docs:api": "typedoc",
    "docs:dev": "typedoc && vitepress dev docs",
    "docs:build": "typedoc && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "pre-commit": "npm run format && npm run lint && npm run typecheck && npm test"
  },
  "dependencies": {
    "content-disposition": "^1.1.0",
    "express": "^5.2.1",
    "multer": "^2.2.0",
    "openapi-types": "^12.1.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@scalar/api-reference": "^1.0.0",
    "redoc": "^2.0.0",
    "swagger-ui-dist": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "@scalar/api-reference": {
      "optional": true
    },
    "redoc": {
      "optional": true
    },
    "swagger-ui-dist": {
      "optional": true
    }
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@eslint/js": "^10.0.1",
    "@scalar/api-reference": "^1.60.0",
    "@types/content-disposition": "^0.5.9",
    "@types/express": "^5.0.6",
    "@types/http-errors": "^2.0.5",
    "@types/multer": "^2.1.0",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "http-errors": "^2.0.1",
    "prettier": "^3.8.4",
    "redoc": "^2.5.3",
    "supertest": "^7.2.2",
    "swagger-ui-dist": "^5.32.6",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typedoc-vitepress-theme": "^1.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.9"
  }
}
