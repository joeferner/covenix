                "properties": {
                  "photos": {
                    "maxItems": 8,
                    "type": "array",
                    "items": {
                      "type": "string",
                      "format": "binary",
                      "contentEncoding": "binary",
                      "maxLength": 5000000,
                      "anyOf": [
                        {
                          "contentMediaType": "image/png"
                        },
                        {
                          "contentMediaType": "image/jpeg"
