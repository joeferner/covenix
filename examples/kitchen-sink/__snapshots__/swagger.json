                  ],
                  "additionalProperties": false
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ],
        "summary": "Avatar URL for a user (no method-level schema on this route)",
        "description": "Returns a URL string. Superseded by `GET {id}/avatar/raw`, which streams the image with HTTP Range support.",
        "operationId": "getUserAvatarUrl",
        "deprecated": true
      },
      "post": {
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UploadResult"
                }
              }
            }
          },
          "404": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        },
        "tags": [
          "Users"
        ],
        "summary": "Upload an avatar image for a user",
        "operationId": "uploadAvatar",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "avatar": {
                    "type": "string",
                    "format": "binary",
                    "contentEncoding": "binary",
                    "maxLength": 2000000,
                    "anyOf": [
                      {
                        "contentMediaType": "image/png"
                      },
                      {
                        "contentMediaType": "image/jpeg"
                      }
                    ]
                  },
                  "caption": {
                    "type": "string",
                    "maxLength": 140
                  }
                },
                "required": [
                  "avatar"
                ],
                "additionalProperties": false
              }
            }
          }
        }
      }
    },
