{
  "compilerOptions": {
    "module": "nodenext",
    "target": "esnext",
    "types": ["reflect-metadata", "node"],
    "strict": true,
    "experimentalDecorators": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": ["src"]
}
